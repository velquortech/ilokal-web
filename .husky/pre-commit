#!/bin/sh
# .husky/pre-commit
#
# Pre-commit hook: Validate service imports and run linting
#
# This hook runs before each commit to ensure:
# - No server-only code imported in client files
# - Code passes eslint checks
# - Proper service boundary enforcement
#

echo "🔍 Running pre-commit checks..."

# Run service import validation
echo "  • Checking service imports..."
node WORKFLOW/tools/validateServiceImports.js
if [ $? -ne 0 ]; then
  echo "❌ Pre-commit check failed"
  exit 1
fi

# Run linting on staged files
echo "  • Running eslint..."
yarn lint -- --fix
if [ $? -ne 0 ]; then
  echo "❌ Linting failed"
  exit 1
fi

# Stage the fixed files
git add .

echo "✅ Pre-commit checks passed"
