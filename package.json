{
  "name": "ilokal-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:types": "supabase gen types typescript --local > lib/types/database.ts",
    "test": "vitest",
    "format:prettier": "yarn prettier --write .",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:unit": "vitest run --reporter=verbose --exclude=\"**/*.integration.test.ts\"",
    "test:integration": "vitest run --reporter=verbose \"integration.test\"",
    "test:products": "vitest run --reporter=verbose \"__test__/\"",
    "test:products:unit": "vitest run --reporter=verbose \"__test__/features/product-query\" \"__test__/features/product-service\" \"__test__/pages/product-catalogues\"",
    "test:products:integration": "vitest run --reporter=verbose \"__test__/features/product-api\" \"__test__/features/product-search\" \"__test__/features/product-analytics\" \"__test__/pages/mobile\"",
    "check:protected": "node WORKFLOW/tools/checkProtectedRoutes.js",
    "check:imports": "node WORKFLOW/tools/validateServiceImports.js",
    "analyze:usage": "node WORKFLOW/tools/analyzeServiceUsage.js",
    "ci:checks": "yarn lint --fix && yarn check:protected && yarn check:imports && yarn analyze:usage && yarn test:run",
    "pre-push": "yarn lint && yarn check:protected && yarn check:imports && yarn test:run && yarn build",
    "prepare": "husky",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.76.1",
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/react-table": "^8.21.3",
    "autoprefixer": "^10.4.27",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.15",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "motion": "^12.29.2",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-intersection-observer": "^10.0.2",
    "react-leaflet": "^5.0.0",
    "recharts": "2.15.4",
    "shadcn-ui": "^0.9.5",
    "sonner": "^2.0.7",
    "supabase": "^2.101.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@next/eslint-plugin-next": "^16.1.6",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "^4.1.0",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "shadcn": "^4.1.1",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.54.0",
    "typescript-memoize": "^1.1.1",
    "vitest": "^4.1.0"
  }
}
